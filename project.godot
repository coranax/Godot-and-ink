; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Visual Novel Ink Test"
run/main_scene="uid://d118s5e01ss6h"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://music/default_bus_layout.tres"

[autoload]

__InkRuntime="*uid://cgy2h20a8ho5g"

[display]

window/size/viewport_width=1200
window/size/viewport_height=800
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/inkgd/plugin.cfg")

[gui]

theme/default_font_multichannel_signed_distance_field=true

[inkgd]

register_templates=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.072842635, 0.072842635, 0.072842635, 1)
